<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="tymur">
        <sqlFile path="schema.sql" relativeToChangelogFile="true"/>
    </changeSet>

    <changeSet id="2" author="tymur">
        <addColumn tableName="listeners">
            <column name="score" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="3" author="tymur">
        <sqlFile path="channel-schema.sql" relativeToChangelogFile="true"/>
    </changeSet>

    <changeSet id="4" author="tymur">
        <comment>Store advertiser phone and name (from Otodom listings) for phone-based agency stats</comment>
        <addColumn tableName="feed_offers">
            <column name="phone" type="varchar(32)"/>
            <column name="advertiser_name" type="varchar(255)"/>
        </addColumn>
        <createIndex tableName="feed_offers" indexName="idx_feed_offers_phone">
            <column name="phone"/>
        </createIndex>
    </changeSet>

    <changeSet id="5" author="tymur">
        <comment>Owner-direct flag ("bezpośrednio") — precision gate for no-commission channel publishing</comment>
        <addColumn tableName="feed_offers">
            <column name="direct" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <!-- Backfill existing rows from the title only; descriptions were never stored. Excludes the
             commission-waiver phrasing, which leans operator/agency rather than owner-direct. -->
        <sql>
            UPDATE feed_offers
            SET direct = true
            WHERE title ~* '(bezpo[śs]redni|bez\s+po[śs]rednik|prywatnie|od\s+w[łl]a[śs]cicie)'
        </sql>
    </changeSet>

</databaseChangeLog>
